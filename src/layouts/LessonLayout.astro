---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import LessonCheckbox from '../components/progress/LessonCheckbox';
import { registerVisit, getUserActivityProgress } from "@/lib/progress/utils";

interface Props {
	title: string;
    slug: string;
	headings: { depth: number; slug: string; text: string }[];
    prevLesson?: { slug: string; title: string };
    nextLesson?: { slug: string; title: string };
}

const { title, slug, headings, prevLesson, nextLesson } = Astro.props;

// Filter headings for TOC (H2 and H3 only)
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);

// Progress Logic
let activityId = `lesson-${slug.replace(/\//g, "-")}`;
let initialCompleted = false;

const { supabase, session } = Astro.locals;

// Only run on server if we have access to Supabase session
if (session?.user) {
    try {
        // Register visit
        await registerVisit(supabase, session.user.id, activityId);
        
        // Get status
        const progress = await getUserActivityProgress(supabase, session.user.id, activityId);
        initialCompleted = progress?.status === 'completed';
    } catch (e) {
        console.error("Error in lesson progress logic:", e);
    }
}
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Academia Seguidor de Luz</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
	</head>
	<body class="bg-bg-main text-text-main font-sans selection:bg-brand-orange/30 selection:text-brand-orange antialiased">
		<!-- Global Header / Top Bar -->
		<header class="flex items-center justify-between p-4 border-b border-border-dark bg-white shadow-sm sticky top-0 z-50">
			<div class="flex items-center gap-8">
                <!-- Logo & Brand (Desktop/Mobile) -->
                <a href="/" class="flex items-center gap-3 group">
                    <div class="w-10 h-10 bg-brand-orange rounded-xl shadow-[0_0_15px_rgba(255,171,25,0.3)] flex items-center justify-center font-bold text-white text-lg transition-transform group-hover:scale-105">💡</div>
                    <span class="font-display font-black tracking-tighter text-slate-800 text-lg hidden sm:block">Seguidor de Luz</span>
                </a>

                <!-- Desktop Quick Tools -->
                <nav class="hidden lg:flex items-center gap-1 p-1 bg-slate-100 rounded-2xl border border-slate-200">
                    <a href="/simulador" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-brand-orange hover:bg-white rounded-xl transition-all">Simulador</a>
                </nav>
            </div>

			<div class="flex items-center gap-4">
                <button id="menu-toggle" class="lg:hidden p-2 text-slate-600 hover:text-brand-orange active:scale-95 transition-all" aria-label="Abrir menú">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                    </svg>
                </button>
            </div>
		</header>

		<div class="flex">
			<Sidebar />

			<!-- main Content Area -->
			<main class="flex-1 flex flex-col min-h-screen overflow-x-hidden">
				<div class="flex-1 max-w-7xl mx-auto w-full px-6 py-12 lg:py-20 grid grid-cols-1 lg:grid-cols-12 gap-12">
					
                    <!-- Central Content (prose) -->
                    <article class="lg:col-span-8 2xl:col-span-9">
                        <div class="prose prose-slate prose-orange max-w-none 
                                    prose-headings:font-display prose-headings:font-black prose-headings:tracking-tight prose-headings:text-slate-800
                                    prose-h1:text-5xl lg:prose-h1:text-6xl
                                    prose-p:text-slate-600 prose-p:leading-relaxed prose-p:text-lg
                                    prose-a:text-brand-blue prose-a:font-bold prose-a:no-underline hover:prose-a:underline
                                    prose-strong:text-slate-800 prose-strong:font-bold
                                    prose-code:text-brand-blue prose-code:bg-brand-blue/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-lg prose-code:before:content-none prose-code:after:content-none
                                    prose-pre:bg-slate-900 prose-pre:border prose-pre:border-slate-800 prose-pre:rounded-2xl
                                    prose-img:rounded-3xl prose-img:border prose-img:border-slate-100
                                    prose-blockquote:border-l-brand-orange prose-blockquote:bg-brand-orange/5 prose-blockquote:py-1 prose-blockquote:px-6 prose-blockquote:rounded-r-xl">
                            <slot />
                        </div>
                        
                        <!-- Progress Tracking Checkbox -->
                        <div class="mt-16 mb-8 flex justify-center">
                            <LessonCheckbox 
                                client:visible 
                                activityId={activityId} 
                                initialCompleted={initialCompleted} 
                            />
                        </div>

                        <!-- Navigation Buttons -->
                        <div class="mt-20 pt-12 border-t border-border-dark flex flex-wrap gap-6 justify-between items-center">
                            {prevLesson ? (
                                <a href={`/curso/${prevLesson.slug}`} class="group flex flex-col gap-2 p-6 rounded-2xl bg-white border-2 border-border-dark shadow-[4px_4px_0px_#e2e8f0] hover:shadow-[4px_4px_0px_var(--color-brand-orange)] hover:border-brand-orange transition-all max-w-sm flex-1">
                                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 group-hover:text-brand-orange transition-colors">Anterior</span>
                                    <span class="text-lg font-display font-bold text-slate-800 group-hover:translate-x-1 transition-transform">{prevLesson.title}</span>
                                </a>
                            ) : <div></div>}

                            {nextLesson ? (
                                <a href={`/curso/${nextLesson.slug}`} class="group flex flex-col gap-2 p-6 rounded-2xl bg-white border-2 border-border-dark shadow-[4px_4px_0px_#e2e8f0] hover:shadow-[4px_4px_0px_var(--color-brand-orange)] hover:border-brand-orange transition-all text-right max-w-sm flex-1">
                                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 group-hover:text-brand-orange transition-colors">Siguiente</span>
                                    <span class="text-lg font-display font-bold text-slate-800 group-hover:-translate-x-1 transition-transform">{nextLesson.title}</span>
                                </a>
                            ) : (
                                <div class="w-full mt-8 p-10 rounded-[2.5rem] bg-white border-2 border-border-dark shadow-[6px_6px_0px_#e2e8f0] relative overflow-hidden group">
                                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_50%,rgba(255,171,25,0.05),transparent_50%)]"></div>
                                    <div class="relative z-10 space-y-8">
                                        <div class="space-y-4">
                                            <h3 class="text-3xl font-display font-bold text-slate-800 tracking-tight">¡Felicitaciones! Has completado la teoría. 🎉</h3>
                                            <p class="text-slate-500 text-lg font-medium leading-relaxed max-w-2xl">
                                                Ahora es momento de pasar de la pantalla al hardware. Prepárate para programar tu robot real.
                                            </p>
                                        </div>
                                        
                                        <div class="flex justify-center">
                                             <a href="/simulador" class="flex items-center justify-between gap-6 p-6 w-full max-w-md bg-slate-50 border-2 border-slate-200 rounded-3xl hover:bg-brand-orange hover:text-white hover:border-brand-orange transition-all group/btn active:scale-95 shadow-sm">
                                                 <div class="flex flex-col text-left">
                                                     <span class="text-[10px] uppercase font-black tracking-widest text-slate-400 group-hover/btn:text-white/80">Práctica Final</span>
                                                     <span class="text-xl font-display font-bold text-slate-800 group-hover/btn:text-white">Simulador del Robot</span>
                                                 </div>
                                                 <span class="text-3xl opacity-60 group-hover/btn:opacity-100 transition-opacity">🎮</span>
                                             </a>
                                         </div>

                                        <div class="pt-6 border-t border-slate-100 flex flex-col md:flex-row items-center justify-between gap-6">
                                            <p class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 italic">Siguientes Pasos: Descargar Firmware -> Calibrar Sensores</p>
                                            <a href="/" class="text-xs font-black text-brand-orange hover:text-brand-orange-hover transition-colors uppercase tracking-[0.3em]">Volver al Inicio</a>
                                        </div>
                                    </div>
                                </div>
                            )}
                        </div>
                    </article>

                    <!-- Table of Contents (Right) -->
                    <aside class="hidden lg:block lg:col-span-4 2xl:col-span-3">
                        <div class="sticky top-32 space-y-6">
                            <div class="px-6 py-4 bg-white border border-border-dark rounded-2xl shadow-sm space-y-4">
                                <h4 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400">En esta página</h4>
                                <nav class="flex flex-col gap-3">
                                    {tocHeadings.map(heading => (
                                        <a 
                                            href={`#${heading.slug}`}
                                            class={`text-sm font-medium transition-all hover:text-brand-orange ${heading.depth === 3 ? 'pl-4 text-slate-400' : 'text-slate-600'}`}
                                        >
                                            {heading.text}
                                        </a>
                                    ))}
                                </nav>
                            </div>

                            <div class="p-6 rounded-2xl bg-brand-blue/10 border border-brand-blue/20 space-y-3 shadow-sm">
                                <div class="w-8 h-8 bg-brand-blue rounded-lg flex items-center justify-center text-white font-bold">?</div>
                                <h4 class="text-sm font-display font-bold text-slate-800">¿Necesitas ayuda?</h4>
                                <p class="text-[11px] text-slate-500 leading-relaxed font-semibold">
                                    Si tienes dudas sobre los fundamentos matemáticos, revisa la sección de materiales o vuelve a leer el divisor de voltaje.
                                </p>
                            </div>
                        </div>
                    </aside>
				</div>
				
				<footer class="max-w-7xl mx-auto w-full px-6 py-8 border-t border-border-dark text-[10px] text-slate-400 uppercase tracking-widest font-bold flex justify-between items-center">
					<span>© 2026 Academia Seguidor de Luz</span>
					<span class="text-brand-blue">Open Source Educational Project</span>
				</footer>
			</main>
		<script>
			const menuToggle = document.getElementById('menu-toggle');
			const sidebar = document.getElementById('sidebar');
			const overlay = document.getElementById('sidebar-overlay');

			function toggleMenu() {
				const isHidden = sidebar?.classList.contains('-translate-x-full');
				
				if (isHidden) {
					sidebar?.classList.remove('-translate-x-full');
					overlay?.classList.remove('hidden');
					setTimeout(() => overlay?.classList.remove('opacity-0'), 0);
					document.body.classList.add('overflow-hidden');
				} else {
					sidebar?.classList.add('-translate-x-full');
					overlay?.classList.add('opacity-0');
					setTimeout(() => overlay?.classList.add('hidden'), 300);
					document.body.classList.remove('overflow-hidden');
				}
			}

			menuToggle?.addEventListener('click', toggleMenu);
			overlay?.addEventListener('click', toggleMenu);
		</script>
	</body>
</html>
