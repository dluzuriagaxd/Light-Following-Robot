---
import { getCollection } from "astro:content";
import SponsorBadge from "./SponsorBadge.astro";

interface Props {
    hiddenInitially?: boolean;
}

const { hiddenInitially = false } = Astro.props;
const currentPath = Astro.url.pathname;

// Auth data from middleware
const user = Astro.locals.user;
const role = Astro.locals.role ?? "guest";
const isTeacherOrAdmin = role === "teacher" || role === "admin";

const mainNav = [
    { label: "Inicio", href: "/", icon: "🏠" },
    { label: "Materiales", href: "/materiales", icon: "📦" },
];

const toolNav = [
    {
        label: "💡 Simulador Robot",
        href: "/simulador",
    },
];

// Fetch and group lessons
const allLessons = await getCollection("lessons");

// Get lesson visibility from DB if user is logged in
// For guests: show lesson list (titles only) but no content access
let lessonVisibility: Record<string, boolean> = {};
if (user && Astro.locals.supabase) {
    try {
        const { data } = await Astro.locals.supabase
            .from("lessons_visibility")
            .select("lesson_slug, is_visible");
        if (data) {
            data.forEach((row: any) => {
                lessonVisibility[row.lesson_slug] = row.is_visible;
            });
        }
    } catch (e) {
        // If table doesn't exist yet, default all to visible
    }
}

// Get student progress from DB
let progressMap: Record<string, any> = {}; // slug -> { status, approval_status }
let activitiesMap: Record<string, boolean> = {}; // id -> requires_manual_approval

if (user && Astro.locals.supabase) {
    try {
        // Fetch progress
        const { data: progData } = await Astro.locals.supabase
            .from("user_activity_progress")
            .select("activity_id, status, approval_status")
            .eq("user_id", user.id);
        if (progData) {
            progData.forEach((row: any) => {
                progressMap[row.activity_id] = { status: row.status, approval_status: row.approval_status };
            });
        }

        // Fetch activities
        const { data: actData } = await Astro.locals.supabase
            .from("activities")
            .select("id, requires_manual_approval");
        if (actData) {
            actData.forEach((row: any) => {
                activitiesMap[row.id] = row.requires_manual_approval;
            });
        }
    } catch (e) {
        // Graceful degradation
    }
}

let userParaleloName = null;
let currentSessionDate = new Date();
let sessionDates = [];

if (user && Astro.locals.supabase && role === "student") {
    try {
        const { data: profile } = await Astro.locals.supabase.from("user_profile").select("paralelo").eq("user_id", user.id).single();
        if (profile?.paralelo) {
            userParaleloName = profile.paralelo;
            const { data: parData } = await Astro.locals.supabase.from("paralelos").select("id").eq("name", userParaleloName).single();
            if (parData?.id) {
                const { data: sessData } = await Astro.locals.supabase.from("class_sessions").select("session_date").eq("paralelo_id", parData.id).order("session_date");
                if (sessData) {
                    sessionDates = sessData.map((s: any) => new Date(s.session_date));
                }
            }
        }
    } catch (e) {
        // Ignore errors
    }
}

const modulesMap = allLessons.reduce(
    (acc, lesson) => {
        const slugParts = lesson.slug.split("/");
        const moduleKey = slugParts.length > 1 ? slugParts[0] : "00-general";
        if (!acc[moduleKey]) acc[moduleKey] = [];
        acc[moduleKey].push(lesson);
        return acc;
    },
    {} as Record<string, any[]>,
);

const sortedModuleKeys = Object.keys(modulesMap).sort();
const modules = sortedModuleKeys.map((key) => ({
    key,
    label: key
        .replace(/^\d+-/, "")
        .replace(/-/g, " ")
        .replace(/\b\w/g, (l) => l.toUpperCase()),
    lessons: modulesMap[key].sort((a, b) => a.data.order - b.data.order),
}));

// Count overall progress
const totalLessons = allLessons.length;
const completedLessons = Object.values(progressMap).filter(s => s === "completed").length;
const progressPct = totalLessons > 0 ? Math.round((completedLessons / totalLessons) * 100) : 0;

function isModuleActive(moduleKey: string) {
    return currentPath.includes(`/curso/${moduleKey}`);
}

const moduleColors: Record<string, { text: string; bg: string; border: string; activeBg: string; itemActive: string }> = {
    "01-fundamentos": {
        text: "text-blue-700",
        bg: "bg-blue-50",
        border: "border-blue-200",
        activeBg: "bg-brand-blue text-white",
        itemActive: "text-blue-700 bg-blue-50 border-l-4 border-brand-blue pl-3",
    },
    "02-sensores": {
        text: "text-green-700",
        bg: "bg-green-50",
        border: "border-green-200",
        activeBg: "bg-brand-green text-white",
        itemActive: "text-green-700 bg-green-50 border-l-4 border-brand-green pl-3",
    },
    "03-motores": {
        text: "text-purple-700",
        bg: "bg-purple-50",
        border: "border-purple-200",
        activeBg: "bg-brand-purple text-white",
        itemActive: "text-purple-700 bg-purple-50 border-l-4 border-brand-purple pl-3",
    },
    "04-armado": {
        text: "text-orange-700",
        bg: "bg-orange-50",
        border: "border-orange-200",
        activeBg: "bg-brand-orange text-white",
        itemActive: "text-orange-700 bg-orange-50 border-l-4 border-brand-orange pl-3",
    },
};

// User display name
const displayName = user?.user_metadata?.full_name ?? user?.email?.split("@")[0] ?? null;
---

<!-- Sidebar -->
<aside
    id="sidebar"
    class:list={[
        "fixed left-0 top-0 bottom-0 z-50 w-72 bg-white border-r border-slate-200 transform -translate-x-full transition-all duration-300 ease-in-out shrink-0 shadow-lg",
        {
            "lg:static lg:top-0 lg:translate-x-0 lg:h-screen lg:flex lg:flex-col lg:shadow-none":
                !hiddenInitially,
        },
        { "lg:fixed lg:h-full lg:top-0": hiddenInitially },
    ]}
>
    <div class="flex flex-col h-full p-6">
        <!-- Sidebar Header -->
        <div class="flex items-center justify-between mb-6 lg:hidden">
            <div class="flex items-center gap-3">
                <div
                    class="w-10 h-10 bg-brand-orange rounded-xl shadow-[0_0_15px_rgba(255,171,25,0.3)] flex items-center justify-center font-bold text-white text-lg"
                >
                    💡
                </div>
                <span class="font-bold tracking-tight text-slate-800"
                    >Seguidor de Luz</span
                >
            </div>
            <button
                id="sidebar-close"
                class="p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-all"
                aria-label="Cerrar menú"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- User Info Card (logged in) -->
        {user ? (
            <div class="mb-5 p-3 bg-slate-50 border border-slate-200 rounded-2xl space-y-2">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-brand-orange/10 rounded-xl flex items-center justify-center text-sm font-black text-brand-orange border border-brand-orange/20">
                        {displayName ? displayName[0].toUpperCase() : "?"}
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="text-xs font-black text-slate-800 truncate">{displayName}</p>
                        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">
                            {role === "teacher" ? "👩‍🏫 Docente" : role === "admin" ? "⚙️ Admin" : "🎓 Estudiante"}
                        </p>
                    </div>
                </div>
                <!-- Progress bar -->
                {role === "student" && (
                    <div class="space-y-1">
                        <div class="flex justify-between text-[9px] font-black text-slate-500 uppercase tracking-wider">
                            <span>Progreso del curso</span>
                            <span class="text-brand-orange">{progressPct}%</span>
                        </div>
                        <div class="w-full bg-slate-200 rounded-full h-1.5 overflow-hidden">
                            <div
                                class="bg-brand-orange h-full rounded-full transition-all"
                                style={`width: ${progressPct}%`}
                            ></div>
                        </div>
                        <p class="text-[9px] text-slate-400 font-semibold text-center">
                            {completedLessons} / {totalLessons} lecciones completadas
                        </p>
                    </div>
                )}
            </div>
        ) : (
            <!-- Guest call-to-action -->
            <a href="/login" class="mb-5 flex items-center justify-center gap-2 p-3 bg-brand-orange/5 border border-brand-orange/20 rounded-2xl text-xs font-black text-brand-orange hover:bg-brand-orange/10 transition-colors">
                <span>🔐</span>
                <span>Iniciar sesión para acceder al curso</span>
            </a>
        )}

        <!-- Navigation -->
        <nav class="flex-1 space-y-6 overflow-y-auto pr-2 custom-scrollbar">
            <div>
                <p
                    class="text-[11px] uppercase tracking-widest text-slate-600 font-extrabold mb-3 px-2 font-sans"
                >
                    Herramientas
                </p>
                <div class="space-y-2">
                    {
                        toolNav.map((item) => (
                            <a
                                href={item.href}
                                class:list={[
                                    "flex items-center justify-between px-4 py-3 text-sm font-black rounded-2xl transition-all duration-200 border-2 group relative overflow-hidden",
                                    currentPath === item.href
                                        ? "bg-brand-orange text-white border-brand-orange shadow-[2px_2px_0px_#e6950f]"
                                        : "bg-[#fffbeb] border-[#ffe0b2] hover:bg-[#ffe0b2] text-[#e6950f]",
                                ]}
                            >
                                <span class="relative z-10 uppercase tracking-wider">
                                    {item.label}
                                </span>
                                <span class="text-xs group-hover:translate-x-1 transition-transform">➔</span>
                            </a>
                        ))
                    }
                </div>
            </div>

            <div>
                <p
                    class="text-[11px] uppercase tracking-widest text-slate-600 font-extrabold mb-3 px-2 font-sans"
                >
                    Plataforma
                </p>
                <div class="space-y-1">
                    {
                        mainNav.map((item) => (
                            <a
                                href={item.href}
                                class:list={[
                                    "flex items-center gap-2 px-4 py-2.5 text-sm font-bold rounded-xl transition-all duration-200 group relative",
                                    currentPath === item.href
                                        ? "text-brand-blue bg-blue-50 border border-brand-blue/30"
                                        : "text-slate-600 hover:text-brand-blue hover:bg-slate-50",
                                ]}
                            >
                                <span class="text-base">{item.icon}</span>
                                <span class="relative z-10">{item.label}</span>
                            </a>
                        ))
                    }
                    <!-- Teacher portal link (teacher/admin only) -->
                    {isTeacherOrAdmin && (
                        <a
                            href="/docente"
                            class:list={[
                                "flex items-center gap-2 px-4 py-2.5 text-sm font-bold rounded-xl transition-all duration-200",
                                currentPath === "/docente"
                                    ? "text-brand-blue bg-blue-50 border border-brand-blue/30"
                                    : "text-slate-600 hover:text-brand-blue hover:bg-slate-50",
                            ]}
                        >
                            <span class="text-base">🎓</span>
                            <span>Portal del Docente</span>
                        </a>
                    )}
                </div>
            </div>

            <div>
                <p
                    class="text-[11px] uppercase tracking-widest text-slate-600 font-extrabold mb-3 px-2 font-sans"
                >
                    Curso
                </p>
                <div class="space-y-5">
                    {
                        modules.map((mod) => {
                            const theme = moduleColors[mod.key] || {
                                text: "text-slate-800",
                                bg: "bg-slate-100",
                                border: "border-slate-200",
                                activeBg: "bg-slate-700 text-white",
                                itemActive: "text-slate-800 bg-slate-100/50 border-l-4 border-slate-700 pl-3",
                            };
                            const isActive = isModuleActive(mod.key);
                            return (
                                <details class="space-y-2 group/module" open={isActive}>
                                    <summary
                                        class:list={[
                                            "w-full flex items-center justify-between px-3 py-2 text-[10px] font-black uppercase tracking-[0.15em] rounded-xl border transition-all cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden",
                                            isActive
                                                ? `${theme.activeBg} ${theme.border}`
                                                : `${theme.text} ${theme.bg} ${theme.border}`,
                                        ]}
                                    >
                                        <span>{mod.label}</span>
                                        <span class="text-xs transition-transform duration-200 group-open/module:rotate-90">▶</span>
                                    </summary>
                                    <div class="space-y-1 ml-2 border-l-2 border-slate-100 pl-2">
                                        {(() => {
                                            let previousLessonApproved = true;

                                            return mod.lessons.map((lesson, idx) => {
                                                const lessonSlug = lesson.slug;
                                                const isLessonActive = currentPath.includes(lessonSlug);
                                                
                                                // 1. Check if lesson is explicitly hidden by teacher
                                                const isVisible = lessonVisibility[lessonSlug] !== false;
                                                
                                                // 2. Check progress & approval status
                                                const activityId = `lesson-${lessonSlug.replace(/\//g, "-")}`;
                                                const progressObj = progressMap[activityId] || {};
                                                const lessonStatus = progressObj.status;
                                                const approvalStatus = progressObj.approval_status;
                                                const isCompleted = lessonStatus === "completed";
                                                const requiresApproval = activitiesMap[activityId] ?? true;

                                                // A lesson is considered "Verde" (approved/passed) if:
                                                // It requires manual approval AND is 'approved'
                                                // OR it doesn't require manual approval AND is 'completed'
                                                const isVerde = (requiresApproval && approvalStatus === 'approved') || (!requiresApproval && isCompleted);

                                                // 3. Date-based gating
                                                // We find the overall index of this lesson across all modules to map to week/session
                                                const overallIndex = allLessons.findIndex(l => l.slug === lessonSlug);
                                                let dateLocked = false;
                                                if (sessionDates.length > 0 && overallIndex >= 0) {
                                                    const sessionDate = sessionDates[overallIndex];
                                                    if (sessionDate && new Date() < sessionDate) {
                                                        dateLocked = true;
                                                    }
                                                }

                                                // Evaluate locked status
                                                let isLocked = false;
                                                if (!isTeacherOrAdmin) {
                                                    if (!isVisible) isLocked = true;
                                                    else if (dateLocked) isLocked = true;
                                                    else if (!previousLessonApproved) isLocked = true;
                                                }

                                                // Guests see title but no link to content
                                                if (!user) {
                                                    return (
                                                        <div class="flex items-center gap-2 px-3 py-2 text-xs font-bold rounded-lg text-slate-400 cursor-default">
                                                            <span class="text-xs">🔒</span>
                                                            <span>{lesson.data.title}</span>
                                                        </div>
                                                    );
                                                }

                                                // If locked
                                                if (isLocked) {
                                                    previousLessonApproved = isVerde;
                                                    return (
                                                        <div class="flex items-center gap-2 px-3 py-2 text-xs font-bold rounded-lg text-slate-400 cursor-default" title={dateLocked ? "Todavía no es la fecha de esta clase" : "Debes aprobar la lección anterior"}>
                                                            <span class="text-xs">🔒</span>
                                                            <span class="opacity-60">{lesson.data.title}</span>
                                                        </div>
                                                    );
                                                }

                                                // Status Icon logic
                                                let statusIcon = "○";
                                                if (isTeacherOrAdmin && !isVisible) statusIcon = "👁️";
                                                else if (isVerde) statusIcon = "✅";
                                                else if (approvalStatus === 'pending') statusIcon = "⏳";
                                                else if (approvalStatus === 'rejected') statusIcon = "❌";
                                                else if (isCompleted) statusIcon = "✅";

                                                previousLessonApproved = isVerde;

                                                return (
                                                    <a
                                                        href={`/curso/${lessonSlug}`}
                                                        class:list={[
                                                            "flex items-center gap-2 px-3 py-2 text-xs font-bold rounded-lg transition-all duration-200 group relative",
                                                            isLessonActive
                                                                ? `${theme.itemActive} font-extrabold`
                                                                : "text-slate-600 hover:text-slate-900 hover:bg-slate-50",
                                                        ]}
                                                    >
                                                        <span class="text-xs shrink-0">
                                                            {statusIcon}
                                                        </span>
                                                        <span class="relative z-10">{lesson.data.title}</span>
                                                    </a>
                                                );
                                            });
                                        })()}
                                    </div>
                                </details>
                            );
                        })
                    }
                </div>
            </div>
        </nav>

        <!-- Bottom: Logout / Login + Sponsor -->
        <div class="mt-auto pt-6 border-t border-slate-100 space-y-3">
            {user ? (
                <form method="POST" action="/api/auth/logout">
                    <button
                        type="submit"
                        class="w-full px-4 py-2.5 text-xs font-black text-slate-500 hover:text-red-600 hover:bg-red-50 rounded-xl transition-all border border-transparent hover:border-red-100 uppercase tracking-wider text-center"
                    >
                        Cerrar sesión
                    </button>
                </form>
            ) : (
                <a
                    href="/login"
                    class="block w-full px-4 py-2.5 text-xs font-black text-center text-brand-orange bg-brand-orange/5 hover:bg-brand-orange/10 rounded-xl transition-all border border-brand-orange/20 uppercase tracking-wider"
                >
                    Iniciar sesión →
                </a>
            )}
            <SponsorBadge />
        </div>
    </div>
</aside>

<!-- Sidebar Overlay -->
<div
    id="sidebar-overlay"
    class:list={[
        "fixed inset-0 bg-black/40 backdrop-blur-xs z-40 hidden transition-opacity duration-300 opacity-0",
        { "lg:hidden": !hiddenInitially },
    ]}
>
</div>
