---
interface Props {
  sponsorName?: string;
  logoUrl?: string;
}

const { sponsorName = "Sponsor Name", logoUrl } = Astro.props;
---

<div class="flex flex-col gap-2 p-3 rounded-lg border border-border-dark bg-surface-dark/30 max-h-[80px] overflow-hidden grayscale opacity-50 transition-all duration-300 hover:grayscale-0 hover:opacity-100 group">
  <span class="text-[10px] uppercase tracking-wider text-white/40 font-semibold group-hover:text-brand-orange transition-colors">
    Project supported by
  </span>
  <div class="flex items-center gap-2">
    {logoUrl ? (
      <img src={logoUrl} alt={sponsorName} class="h-6 w-auto" />
    ) : (
      <div class="h-6 w-6 rounded bg-white/10 flex items-center justify-center">
        <div class="w-3 h-3 bg-white/20 rounded-full"></div>
      </div>
    )}
    <span class="text-sm font-medium text-white/80 line-clamp-1">{sponsorName}</span>
  </div>
</div>
